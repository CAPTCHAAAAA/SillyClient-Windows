{
  "name": "sillyclient-windows",
  "version": "1.5.0",
  "description": "SillyClient for Windows",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "check": "tsc --noEmit",
    "build": "tsc",
    "pack": "npm run build && electron-builder --win",
    "prepare:runtime": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/Prepare-NodeRuntime.ps1",
    "sync:frontend": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/Sync-Frontend.ps1"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "npm@10.9.2",
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.sillyclient",
    "productName": "SillyClient",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "files": [
      "dist/**/*",
      "frontend-dist/**/*",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "runtime/node",
        "to": "runtime/node",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "fast-json-stable-stringify": "^2.1.0"
  }
}
